/* Text */
var(--components-color-foreground-primary)                 /* #121319 */
var(--components-color-foreground-secondary)               /* #5f6272 */
var(--components-color-foreground-tertiary)                /* #74748a */

/* Borders */
var(--components-color-border-default)                     /* #cccdd4 */
var(--components-color-border-interactive-default)         /* #000049 */

/* Radius */
var(--radius-onsurface-default)                            /* 8px */
var(--radius-onpage-default)                               /* 16px */
var(--radius-elevatedsurface-default)                      /* 24px */

/* Spacing */
var(--components-spacing-xs)    /* 8px */
var(--components-spacing-sm)    /* 12px */
var(--components-spacing-md)    /* 16px */
var(--components-spacing-lg)    /* 24px */
var(--components-spacing-xl)    /* 32px */

/* Typography */
var(--font-family-display)      /* 'Axiforma for Affirm', SF Pro Display fallbacks */
var(--font-family-body)         /* 'Calibre', SF Pro Text fallbacks */
var(--semantic-size-body-small)   /* 14px */
var(--semantic-size-body-medium)  /* 16px — default body */
var(--semantic-size-body-large)   /* 18px */
var(--semantic-size-heading-md)   /* 24px — headline/Medium */
var(--font-weight-regular)        /* 400 */
var(--font-weight-medium)         /* 500 */
var(--font-weight-semibold)       /* 600 */
var(--font-weight-bold)           /* 700 — headline-Small ONLY */
