# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Resend ───────────────────────────────────────────────────────────────────
# Your Resend API key — get it from https://resend.com/api-keys
# Used by the demo sender page (?mode=demo) to send magic link emails from the browser.
# For the Quicksilver backend, set RESEND_API_KEY as a Quicksilver secret instead.
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Mock API toggle ──────────────────────────────────────────────────────────
# Set to "true" to enable MSW service worker in production builds (Quickhost).
# The mock service worker intercepts all /api/upay/* calls in the browser —
# no real backend needed for the payment flow demo.
# Set to "false" (or omit) when pointing at the live Quicksilver backend.
VITE_ENABLE_MOCKS=true

# ─── Backend base URL ─────────────────────────────────────────────────────────
# Prefix prepended to all /api/upay/* fetches.
# Empty (default) → MSW intercepts requests in-browser (paired with VITE_ENABLE_MOCKS=true).
# Set to a real backend origin to bypass MSW and call the live service:
#   VITE_API_BASE_URL=https://thor-portal.affirm-thor.com
VITE_API_BASE_URL=
